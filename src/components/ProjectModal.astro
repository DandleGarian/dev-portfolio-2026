---
// Project detail modal — one native <dialog> (lives in the Layout so it works
// on standalone /work AND when /work is injected in the drawer). Each project's
// body is an inert <template>, cloned into the dialog on open; one live carousel
// at a time keeps the IntersectionObserver simple and future-proofs real images.
import { projects } from "../data/projects";
---

<dialog id="project-modal" class="project-modal" aria-labelledby="pm-title">
  <div
    class="flex shrink-0 items-center justify-between gap-4 border-b border-border bg-surface-2 px-5 py-4"
  >
    <span id="pm-header" class="text-label-md uppercase tracking-widest text-primary">
      PROJECT // DETAILS
    </span>
    <button
      id="pm-close"
      type="button"
      aria-label="Close project details"
      class="flex items-center gap-2 text-label-md uppercase text-foreground transition-colors hover:text-primary"
    >
      <span>CLOSE</span>
      <span class="hidden text-label-sm text-muted sm:inline">[ESC]</span>
      <span aria-hidden="true" class="material-symbols-outlined">close</span>
    </button>
  </div>

  <div id="pm-body" class="grow overflow-y-auto"></div>
</dialog>

{
  projects.map((p) => (
    <template id={`pm-${p.id}`}>
      <div class="pm-carousel">
        <ul
          class="pm-track no-scrollbar flex aspect-video snap-x snap-mandatory overflow-x-auto"
          tabindex="0"
          role="group"
          aria-roledescription="carousel"
          aria-label="Project screens"
        >
          {p.slides.map((slide, i) => (
            <li
              class="pm-slide relative w-full flex-none snap-start"
              role="group"
              aria-roledescription="slide"
              aria-label={`Image ${i + 1} of ${p.slides.length}`}
            >
              <div class="flex h-full w-full flex-col items-center justify-center gap-3 bg-surface-2 text-muted">
                <span aria-hidden="true" class="material-symbols-outlined text-[48px]">
                  deployed_code
                </span>
                <span class="text-label-sm uppercase tracking-widest">
                  SCREEN_0{i + 1}
                </span>
              </div>
              {slide.caption && (
                <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-background to-transparent p-4">
                  <span class="text-label-sm uppercase tracking-widest text-foreground">
                    {slide.caption}
                  </span>
                </div>
              )}
            </li>
          ))}
        </ul>

        {p.slides.length > 1 && (
          <div class="pm-dots mt-4 flex justify-center gap-2" aria-hidden="true">
            {p.slides.map((_, i) => (
              <button type="button" class="pm-dot h-2 w-2 bg-border transition-colors" aria-label={`Go to image ${i + 1}`} />
            ))}
          </div>
        )}
      </div>

      <div class="flex flex-col gap-6 p-6 md:p-8">
        <div>
          <h3 id="pm-title" class="mb-2 wrap-break-word text-headline-md text-foreground">
            {p.name}
          </h3>
          <p class="text-body-md text-muted">{p.description}</p>
        </div>

        <dl class="grid grid-cols-1 gap-4 border-t border-border pt-6 sm:grid-cols-3">
          <div>
            <dt class="mb-1 text-label-sm uppercase text-muted">ROLE</dt>
            <dd class="text-body-md text-foreground">{p.role}</dd>
          </div>
          <div>
            <dt class="mb-1 text-label-sm uppercase text-muted">STACK</dt>
            <dd class="text-body-md text-foreground">{p.stack}</dd>
          </div>
          <div>
            <dt class="mb-1 text-label-sm uppercase text-muted">STATUS</dt>
            <dd class="text-body-md text-primary">{p.status}</dd>
          </div>
        </dl>

        {p.url && (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 border border-primary px-8 py-4 text-label-md uppercase text-primary transition-colors duration-200 hover:bg-primary hover:text-on-primary"
          >
            INITIALIZE_REMOTE_ACCESS
            <span aria-hidden="true" class="material-symbols-outlined text-[18px]">
              arrow_outward
            </span>
          </a>
        )}
      </div>
    </template>
  ))
}

<script>
  const modal = document.getElementById("project-modal") as HTMLDialogElement | null;
  const body = document.getElementById("pm-body");
  const header = document.getElementById("pm-header");
  const closeBtn = document.getElementById("pm-close");

  if (modal && body) {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let lastTrigger: HTMLElement | null = null;
    let savedOverflow = "";
    let io: IntersectionObserver | null = null;
    let goTo: (i: number) => void = () => {};
    let getCurrent: () => number = () => 0;

    function initCarousel() {
      if (io) {
        io.disconnect();
        io = null;
      }
      const track = body!.querySelector<HTMLElement>(".pm-track");
      const slides = [...body!.querySelectorAll<HTMLElement>(".pm-slide")];
      const dots = [...body!.querySelectorAll<HTMLButtonElement>(".pm-dot")];
      let current = 0;
      getCurrent = () => current;

      const setActive = (i: number) => {
        current = i;
        dots.forEach((d, di) => {
          const on = di === i;
          d.classList.toggle("bg-primary", on);
          d.classList.toggle("bg-border", !on);
        });
      };
      goTo = (i: number) => {
        if (!slides.length) return;
        const idx = (i + slides.length) % slides.length; // wrap → loop
        slides[idx].scrollIntoView({
          behavior: prefersReduced ? "auto" : "smooth",
          inline: "start",
          block: "nearest",
        });
      };
      dots.forEach((d, i) => d.addEventListener("click", () => goTo(i)));
      if (dots.length) setActive(0);

      if (slides.length > 1 && track) {
        io = new IntersectionObserver(
          (entries) =>
            entries.forEach((e) => {
              if (e.isIntersecting) setActive(slides.indexOf(e.target as HTMLElement));
            }),
          { root: track, threshold: 0.6 },
        );
        slides.forEach((s) => io!.observe(s));
      }
    }

    function open(id: string, trigger: HTMLElement | null) {
      const tpl = document.getElementById(`pm-${id}`) as HTMLTemplateElement | null;
      if (!tpl) return;
      lastTrigger = trigger;
      body!.replaceChildren(tpl.content.cloneNode(true));
      body!.scrollTop = 0;
      if (header) header.textContent = `${id} // DETAILS`;
      savedOverflow = document.body.style.overflow;
      document.body.style.overflow = "hidden";
      modal!.showModal();
      initCarousel();
    }

    // Card triggers are <button data-project-id> — delegated, so they work for
    // cards on the standalone page and inside the drawer-injected content.
    document.addEventListener("click", (event) => {
      const trigger = (event.target as Element)?.closest?.<HTMLElement>("[data-project-id]");
      if (trigger?.dataset.projectId) {
        event.preventDefault();
        open(trigger.dataset.projectId, trigger);
      }
    });

    closeBtn?.addEventListener("click", () => modal.close());
    modal.addEventListener("click", (event) => {
      if (event.target === modal) modal.close(); // backdrop / outside the panel
    });
    // ESC is handled natively (closes the top-most dialog = this modal, not the drawer).

    modal.addEventListener("keydown", (event) => {
      if (event.key === "ArrowRight") {
        event.preventDefault();
        goTo(getCurrent() + 1);
      } else if (event.key === "ArrowLeft") {
        event.preventDefault();
        goTo(getCurrent() - 1);
      }
    });

    modal.addEventListener("close", () => {
      document.body.style.overflow = savedOverflow; // correct even with the drawer open beneath
      io?.disconnect();
      io = null;
      body!.replaceChildren();
      if (lastTrigger && document.contains(lastTrigger)) lastTrigger.focus();
      lastTrigger = null;
    });
  }
</script>
