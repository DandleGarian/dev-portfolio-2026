---
type PageId = "index" | "work" | "specs" | "contact";

interface Props {
  active?: PageId;
}

const { active = "index" } = Astro.props;

const links: { id: PageId; label: string; href: string }[] = [
  { id: "index", label: "01 // INDEX", href: "/" },
  { id: "work", label: "02 // WORK", href: "/work" },
  { id: "specs", label: "03 // SPECS", href: "/specs" },
  { id: "contact", label: "04 // SEND", href: "/contact" },
];
---

<header
  class="fixed left-0 top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md transition-all duration-200"
>
  <div
    class="mx-auto flex w-full max-w-content items-center justify-between px-5 py-4 md:px-8 lg:px-16"
  >
    <a
      href="/"
      class="flex items-center gap-2 text-headline-md font-bold tracking-tighter text-foreground"
    >
      TERMINAL_VELOCITY
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-6 text-label-md lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={active === l.id ? "page" : undefined}
            class:list={[
              "pb-1 transition-colors",
              active === l.id
                ? "border-b border-primary text-primary"
                : "text-muted hover:text-foreground",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop trailing action -->
    <button
      type="button"
      aria-label="Terminal"
      class="hidden p-2 text-muted transition-colors hover:text-primary lg:flex"
    >
      <span aria-hidden="true" class="material-symbols-outlined">terminal</span>
    </button>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="p-2 text-foreground transition-colors hover:text-primary lg:hidden"
    >
      <span id="nav-toggle-icon" aria-hidden="true" class="material-symbols-outlined">menu</span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-border px-5 pb-4 pt-2 lg:hidden"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          aria-current={active === l.id ? "page" : undefined}
          class:list={[
            "block w-full p-2 text-label-md transition-colors",
            active === l.id
              ? "border-b border-primary text-primary"
              : "text-muted hover:bg-foreground/5 hover:text-foreground",
          ]}
        >
          {l.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-nav");
  const icon = document.getElementById("nav-toggle-icon");

  function setOpen(open: boolean) {
    if (!toggle || !menu || !icon) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    menu.classList.toggle("hidden", !open);
    icon.textContent = open ? "close" : "menu";
  }

  toggle?.addEventListener("click", () => {
    setOpen(toggle.getAttribute("aria-expanded") !== "true");
  });

  // Collapse the mobile menu when a link inside it is chosen (e.g. one that
  // opens the drawer) so it isn't left open behind the panel.
  menu?.addEventListener("click", (event) => {
    if ((event.target as Element)?.closest?.("a")) setOpen(false);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && toggle?.getAttribute("aria-expanded") === "true") {
      setOpen(false);
      toggle.focus();
    }
  });
</script>
