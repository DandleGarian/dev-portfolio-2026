---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects, cardSpecs } from "../data/projects";
---

<Layout title="TERMINAL_VELOCITY // WORK_ARCHIVE" active="work">
  <main
    class="mx-auto w-full max-w-content grow px-5 pb-24 pt-24 md:px-8 md:pt-28 lg:px-16"
  >
    <!-- Section header -->
    <div class="mb-16 max-w-2xl">
      <h1 class="mb-4 text-headline-xl-mobile text-foreground md:text-headline-xl">
        02 // WORK_ARCHIVE
      </h1>
      <p class="text-body-lg text-muted">
        A selection of high-fidelity engineering artifacts. Executed with strict
        adherence to minimal tolerances and robust system architectures.
      </p>
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        projects.map((p) => (
          <ProjectCard
            id={p.id}
            name={p.name}
            specs={cardSpecs(p)}
            description={p.description}
            feature={p.feature}
          />
        ))
      }
    </div>
  </main>
</Layout>
