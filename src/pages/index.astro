---
import Layout from "../layouts/Layout.astro";

const bullets = [
  { pre: "Forging ", hi: "aerospace-inspired interfaces", post: " that prioritize technical clarity." },
  { pre: "Delivering ", hi: "precision-engineered web experiences", post: " across global coordinates." },
  { pre: "Rejecting gradients. Embracing structural lines.", hi: "", post: "" },
];
---

<Layout title="TERMINAL_VELOCITY // INDEX" active="index">
  <main class="flex flex-grow items-center justify-center pt-18 md:pt-25">
    <div class="mx-auto w-full max-w-content px-5 py-6 md:px-16 md:py-30">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
        <!-- Left content column -->
        <div class="order-2 flex flex-col justify-center md:order-1 md:col-span-8">
          <!-- Status chip -->
          <div
            class="mb-8 inline-flex w-fit items-center gap-2 border border-border bg-surface px-3 py-1"
          >
            <span class="h-2 w-2 bg-primary"></span>
            <span class="text-label-sm uppercase tracking-widest text-primary">
              STATUS: ONLINE // SECURE
            </span>
          </div>

          <!-- Headline -->
          <h1
            class="blink-cursor mb-8 text-headline-xl-mobile tracking-tighter text-foreground md:text-headline-xl"
          >
            SYSTEM_BOOT:<br />HELLO_WORLD
          </h1>

          <!-- Bio -->
          <div class="mb-12 max-w-2xl space-y-6">
            <p class="text-body-lg text-muted">
              Executing bio sequence... High-fidelity reductionist engineer
              detected. Specializing in the architecture of infinite canvases
              and void spaces.
            </p>
            <div class="border-l border-border pl-4">
              <ul class="space-y-2">
                {
                  bullets.map((b) => (
                    <li class="flex items-start gap-3 text-label-md text-foreground">
                      <span class="mt-1.5 h-1 w-1 flex-shrink-0 bg-primary" />
                      <span>
                        {b.pre}
                        {b.hi && <span class="text-primary">{b.hi}</span>}
                        {b.post}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href="/work"
              class="group flex items-center justify-center gap-2 border border-primary px-8 py-4 text-label-md uppercase tracking-widest text-primary transition-colors duration-200 hover:bg-primary hover:text-on-primary"
            >
              <span>VIEW_WORK</span>
              <span
                aria-hidden="true"
                class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-1"
                >arrow_forward</span
              >
            </a>
            <button
              type="button"
              class="border border-border bg-surface px-8 py-4 text-label-md uppercase tracking-widest text-foreground transition-colors duration-200 hover:bg-foreground hover:text-background"
            >
              READ_LOGS
            </button>
          </div>
        </div>

        <!-- Right structural accent column (decorative; on top on mobile) -->
        <div class="order-1 flex items-center justify-center md:order-2 md:col-span-4 md:justify-end">
          <div
            class="relative aspect-[3/4] w-full max-w-sm overflow-hidden border border-border bg-surface md:max-w-none"
          >
            <!-- TODO: drop the real photo at public/operator-profile.png -->
            <img
              src="/operator-profile.png"
              alt="Operator profile"
              width="600"
              height="800"
              class="h-full w-full object-cover brightness-75 contrast-125 grayscale"
            />
            <div
              class="pointer-events-none absolute inset-0 border border-primary/20"
            >
            </div>
            <div
              aria-hidden="true"
              class="absolute left-2 top-2 z-20 flex flex-col gap-1"
            >
              <span class="bg-surface/80 px-1 text-[10px] text-primary"
                >ID: TV_RE-001</span
              >
              <span class="bg-surface/80 px-1 text-[10px] text-muted"
                >OP_TYPE: REDUCTIONIST</span
              >
            </div>
            <div
              aria-hidden="true"
              class="absolute bottom-2 right-2 z-20 flex flex-col text-right"
            >
              <span class="bg-surface/80 px-1 text-[10px] text-muted"
                >VERIFIED_PROFILE</span
              >
              <span class="bg-surface/80 px-1 text-[10px] text-primary"
                >AUTH_SECURE</span
              >
            </div>
            <div class="absolute left-0 top-1/2 h-px w-full bg-primary/10"></div>
            <div class="absolute left-1/2 top-0 h-full w-px bg-primary/10"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
