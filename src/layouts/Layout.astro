---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type PageId = "index" | "work" | "specs" | "contact";

interface Props {
  title: string;
  description?: string;
  active?: PageId;
}

const {
  title,
  description = "TERMINAL_VELOCITY — portfolio of a solid, reliable developer.",
  active = "index",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    class="tech-grid-bg flex min-h-screen flex-col bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <Header active={active} />
    <slot />
    <Footer />
  </body>
</html>
